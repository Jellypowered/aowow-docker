# aowow database configuration
# This database is created and managed by aowow-docker
AOWOW_DB_HOST=db
AOWOW_DB_DATABASE=aowow
AOWOW_DB_USER=aowow_user
AOWOW_DB_PASSWORD=aowow_password

# world database (AzerothCore — externally managed)
# Do NOT create or modify this database; it is owned by the AzerothCore deployment
WORLD_DB_HOST=host.docker.internal
WORLD_DB_DATABASE=acore_world
WORLD_DB_USER=world_user
WORLD_DB_PASSWORD=world_password

# auth database (AzerothCore — externally managed)
AUTH_DB_HOST=host.docker.internal
AUTH_DB_DATABASE=acore_auth
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_password

# characters database (AzerothCore — externally managed)
CHARACTERS_DB_HOST=host.docker.internal
CHARACTERS_DB_DATABASE=acore_characters
CHARACTERS_DB_USER=characters_user
CHARACTERS_DB_PASSWORD=characters_password

# If AzCoreWeb already has the correct AzerothCore DB settings, copy the matching
# DB host/user/password values from /bulk/Source/AzCoreWeb/backend/.env.
# On Linux, replace host.docker.internal with the host IP or another reachable DB host.

# mysql root password (for AoWoW database creation only)
MYSQL_ROOT_PASSWORD=rootpassword

# mysql configuration
# max connections (default is 151). uncomment to override.
# MYSQL_MAX_CONNECTIONS=151

# web configuration
WEB_PORT=8080
# hosts for aowow configuration
SITE_HOST=localhost:8080
STATIC_HOST=localhost:8080/static
# account registration: 0 = disable, 1 = enable
AOWOW_ACC_ALLOW_REGISTER=1
# force ssl: 0 = disable, 1 = enable
AOWOW_FORCE_SSL=0
# threads for audio conversion (0 = all available cores)
AOWOW_CONVERSION_THREADS=0

# php-fpm configuration
FPM_PM=dynamic
FPM_PM_MAX_CHILDREN=5
FPM_PM_START_SERVERS=2
FPM_PM_MIN_SPARE_SERVERS=1
FPM_PM_MAX_SPARE_SERVERS=3
FPM_PM_MAX_REQUESTS=0
FPM_REQUEST_TERMINATE_TIMEOUT=0

# aowow limits
AOWOW_SQL_LIMIT_DEFAULT=300
AOWOW_SQL_LIMIT_SEARCH=300
AOWOW_MEMORY_LIMIT=1500M

# build configuration (git repositories)
AOWOW_GIT_URL=https://github.com/Jellypowered/aowow.git
MPQEXTRACTOR_GIT_URL=https://github.com/Sarjuuk/MPQExtractor.git

# world of warcraft client path
# point this to your wow 3.3.5a installation directory
WOW_CLIENT_PATH=/path/to/your/wow-3.3.5a

# wow locales (space-separated list: enUS enGB deDE frFR esES ruRU etc.)
WOW_LOCALE=enUS